---
import CognitoForm from '~/components/widgets/CognitoForm.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Layout from '~/layouts/PageLayout.astro';
import donationSettings from '~/data/settings/donation.json';

const metadata = {
  title: 'Donate',
  description:
    'Support ECRS with a donation and help us continue bringing people together through creative, cooperative recreation.',
  openGraph: { images: [{ url: '/og/default.jpg', width: 1200, height: 630 }] },
};
---

<Layout metadata={metadata}>
  <HeroText tagline={donationSettings.heroTagline} title={donationSettings.heroTitle} />

  <section class="py-8 px-4 max-w-3xl mx-auto">
    <p class="text-center text-muted">{donationSettings.introText}</p>
  </section>

  <CognitoForm formId={donationSettings.cognitoFormId} formName="donation" />
</Layout>
