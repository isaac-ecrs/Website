---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import heroBg from '../../assets/images/hero-bg.jpg';

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map((event) => ({
    params: { slug: event.data.eventSlug },
    props: { event },
  }));
}

const { event } = Astro.props;

const startDate = new Date(event.data.startDate);
const endDate = new Date(event.data.endDate);

const dateOpts: Intl.DateTimeFormatOptions = { month: 'long', day: 'numeric', year: 'numeric' };
const timeOpts: Intl.DateTimeFormatOptions = { hour: 'numeric', minute: '2-digit' };

function formatDateRange(start: Date, end: Date): string {
  const sameDay = start.toDateString() === end.toDateString();
  if (sameDay) {
    return `${start.toLocaleDateString('en-US', dateOpts)}, ${start.toLocaleTimeString('en-US', timeOpts)} – ${end.toLocaleTimeString('en-US', timeOpts)}`;
  }
  if (start.getFullYear() === end.getFullYear()) {
    return `${start.toLocaleDateString('en-US', { month: 'long', day: 'numeric' })} – ${end.toLocaleDateString('en-US', dateOpts)}`;
  }
  return `${start.toLocaleDateString('en-US', dateOpts)} – ${end.toLocaleDateString('en-US', dateOpts)}`;
}

const dateRange = formatDateRange(startDate, endDate);

const loc = event.data.location;
const hasValidAddress = loc.address && !loc.address.toLowerCase().includes('tbd');
const mapsUrl = hasValidAddress
  ? `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(`${loc.address}, ${loc.city}, ${loc.state} ${loc.zip}`)}`
  : null;

const isFuture = startDate > new Date();
---

<BaseLayout
  title={event.data.title}
  description={event.data.shortDescription || event.data.title}
>
  <!-- HERO -->
  <section class="event-hero" style={`background-image: url(${heroBg.src})`}>
    <div class="event-hero-inner">
      <h1>{event.data.title}</h1>
      <p class="hero-date">{dateRange}</p>
    </div>
  </section>

  <!-- KEY INFO -->
  <section class="key-info-bar">
    <div class="container key-info-grid">
      <div class="info-item">
        <span class="info-label">When</span>
        <span class="info-value">{dateRange}</span>
      </div>
      <div class="info-item">
        <span class="info-label">Where</span>
        <span class="info-value">
          {loc.website ? (
            <a href={loc.website} target="_blank" rel="noopener">{loc.venue}</a>
          ) : (
            loc.venue
          )}
          {mapsUrl ? (
            <a class="map-link" href={mapsUrl} target="_blank" rel="noopener">
              {loc.address && <>{loc.address}, </>}{loc.city}, {loc.state}
            </a>
          ) : (
            <span>{loc.city}, {loc.state}</span>
          )}
        </span>
      </div>
      <div class="info-item">
        <span class="info-label">Cost</span>
        <span class="info-value cost-value">{event.data.cost}</span>
      </div>
    </div>
  </section>

  <!-- DESCRIPTION -->
  {event.data.shortDescription && (
    <section class="section section--white">
      <div class="container narrow">
        <p class="event-lead">{event.data.shortDescription}</p>
      </div>
    </section>
  )}

  <!-- HIGHLIGHTS -->
  {event.data.highlights && event.data.highlights.length > 0 && (
    <section class="section section--cream">
      <div class="container">
        <h2 class="section-heading">What to Expect</h2>
        <div class="highlights-grid">
          {event.data.highlights.map((h: any) => (
            <div class="highlight-card">
              <h3>{h.title}</h3>
              <p>{h.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- VENUE DESCRIPTION -->
  {event.data.venueDescription && (
    <section class="section section--white">
      <div class="container narrow">
        <h2 class="section-heading">About the Venue</h2>
        <p>{event.data.venueDescription}</p>
        {event.data.location.website && (
          <a href={event.data.location.website} class="venue-link" target="_blank" rel="noopener">
            Visit venue website →
          </a>
        )}
      </div>
    </section>
  )}

  <!-- REGISTRATION CTA -->
  <section class="section section--dark registration">
    <div class="container">
      <h2>{isFuture ? 'Join Us' : 'Interested?'}</h2>
      <p>
        Email us to register or ask questions about {event.data.title}.
      </p>
      <a
        href={`mailto:${event.data.registrationEmail}`}
        class="btn btn--primary"
      >
        {isFuture ? 'Register by Email' : 'Get in Touch'}
      </a>
      <p class="reg-email">
        <a href={`mailto:${event.data.registrationEmail}`}>
          {event.data.registrationEmail}
        </a>
      </p>
    </div>
  </section>
</BaseLayout>

<style lang="scss">
  @use '../../styles/variables' as *;
  @use '../../styles/mixins' as *;

  // ---- HERO ----
  .event-hero {
    @include parallax-bg(0.55);
    min-height: 50vh;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 3em 1em;
    padding-top: calc(var(--header-total-height) + 3em);

    @include mobile {
      background-attachment: scroll;
      min-height: 40vh;
    }
  }

  .event-hero-inner {
    position: relative;
    z-index: 2;
    text-align: center;
    color: white;
    max-width: 800px;

    h1 {
      font-size: clamp(32px, 6vw, 60px);
      color: white;
      text-transform: uppercase;
      margin-bottom: 0.4em;
    }
  }

  .hero-date {
    font-size: 16px;
    opacity: 0.85;
    letter-spacing: 0.5px;
  }

  // ---- KEY INFO BAR ----
  .key-info-bar {
    background: $color-primary;
    color: white;
    padding: 1.75em 0;
  }

  .key-info-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5em;

    @include mobile {
      grid-template-columns: 1fr;
      gap: 1.25em;
    }
  }

  .info-item {
    display: flex;
    flex-direction: column;
    gap: 0.3em;
  }

  .info-label {
    font-family: $font-heading;
    text-transform: uppercase;
    font-size: 11px;
    letter-spacing: 2px;
    opacity: 0.7;
    font-weight: $font-weight-bold;
  }

  .info-value {
    font-size: 15px;
    line-height: 1.5;
    display: flex;
    flex-direction: column;
    gap: 0.2em;

    a {
      color: $color-accent;
      text-decoration: none;

      &:hover {
        text-decoration: underline;
      }
    }
  }

  .cost-value {
    font-size: 17px;
    font-weight: 700;
    color: $color-accent;
  }

  .map-link {
    font-size: 13px;
    opacity: 0.85;
    color: white !important;
    text-decoration: underline !important;

    &:hover {
      opacity: 1;
    }
  }

  // ---- CONTENT ----
  .narrow {
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }

  .event-lead {
    font-size: 18px;
    line-height: 1.75;
    color: $color-text-dark;
  }

  .section-heading {
    color: $color-primary;
    margin-bottom: 1.25em;
    font-size: 26px;
  }

  // ---- HIGHLIGHTS ----
  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5em;
  }

  .highlight-card {
    background: white;
    border-radius: 6px;
    padding: 1.5em;
    border-top: 3px solid $color-accent;

    h3 {
      font-size: 16px;
      color: $color-primary;
      margin-bottom: 0.5em;
      text-transform: uppercase;
    }

    p {
      font-size: 14px;
      line-height: 1.65;
      color: $color-text-dark;
      margin: 0;
    }
  }

  // ---- VENUE ----
  .venue-link {
    display: inline-block;
    margin-top: 1em;
    color: $color-secondary;
    text-decoration: none;
    font-weight: 600;

    &:hover {
      text-decoration: underline;
    }
  }

  // ---- REGISTRATION ----
  .section--dark {
    background: $color-dark-brown;
    color: white;
  }

  .registration {
    text-align: center;

    h2 {
      color: white;
      margin-bottom: 0.5em;
    }

    > p {
      opacity: 0.85;
      margin-bottom: 1.5em;
      font-size: 17px;
    }

    .reg-email {
      margin-top: 1em;
      font-size: 14px;
      opacity: 0.7;

      a {
        color: $color-accent;
      }
    }
  }
</style>
