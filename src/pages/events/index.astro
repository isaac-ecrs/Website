---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import EventCard from '~/components/widgets/EventCard.astro';
import eventsListSettings from '~/data/settings/events-list.json';
import { formatEventDateRange } from '~/utils/dates';

const allEvents = await getCollection('event', ({ data }) => !data.draft);
// en-CA produces YYYY-MM-DD output (the only locale that does), which lets us
// concatenate directly into a valid ISO string. The timezone is what matters here.
const now = new Date(new Date().toLocaleDateString('en-CA', { timeZone: 'America/New_York' }) + 'T00:00:00Z');

const upcoming = allEvents
  .filter((e) => (e.data.endDate ?? e.data.date) >= now)
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

const past = allEvents
  .filter((e) => (e.data.endDate ?? e.data.date) < now)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const metadata = {
  title: eventsListSettings.heroTitle,
  description: eventsListSettings.heroSubtitle,
};

const allOrdered = [...upcoming, ...past];
const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'ECRS Events',
  url: Astro.site ? new URL('/events', Astro.site).href : 'https://ecrs.org/events',
  itemListElement: allOrdered.map((event, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Event',
      '@id': Astro.site ? new URL(`/events/${event.id}`, Astro.site).href : `https://ecrs.org/events/${event.id}`,
      name: event.data.title,
      startDate: event.data.date.toISOString(),
      ...(event.data.endDate ? { endDate: event.data.endDate.toISOString() } : {}),
      eventStatus:
        (event.data.endDate ?? event.data.date) < now
          ? 'https://schema.org/EventPast'
          : 'https://schema.org/EventScheduled',
      eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
      location: {
        '@type': 'Place',
        name: event.data.location,
        ...(event.data.address ? { address: event.data.address } : {}),
      },
      audience: {
        '@type': 'PeopleAudience',
        audienceType: 'All ages, intergenerational, families',
        suggestedMinAge: 0,
      },
      ...(event.data.excerpt ? { description: event.data.excerpt } : {}),
      url: Astro.site ? new URL(`/events/${event.id}`, Astro.site).href : `https://ecrs.org/events/${event.id}`,
    },
  })),
};
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(itemListJsonLd)} />
  </Fragment>
  <HeroText
    tagline={eventsListSettings.heroTagline}
    title={eventsListSettings.heroTitle}
    subtitle={eventsListSettings.heroSubtitle}
  />

  <!-- ============================================================
       UPCOMING EVENTS
       ============================================================ -->
  <section class="py-12 md:py-16 px-4 max-w-7xl mx-auto" aria-labelledby="upcoming-heading">
    <h2 id="upcoming-heading" class="font-heading text-3xl md:text-4xl font-bold text-heading mb-8">
      {eventsListSettings.upcomingHeading}
    </h2>

    {
      upcoming.length === 0 ? (
        <p class="text-muted text-lg">{eventsListSettings.emptyStateText}</p>
      ) : (
        <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 list-none p-0 m-0" role="list">
          {upcoming.map((event: (typeof upcoming)[0]) => (
            <li>
              <EventCard
                title={event.data.title}
                date={formatEventDateRange(event.data.date, event.data.endDate)}
                location={event.data.location}
                href={`/events/${event.id}`}
                image={event.data.image}
                excerpt={event.data.excerpt}
                registrationDeadline={event.data.registrationDeadline}
                hasRegistration={!!(event.data.registrationUrl || event.data.cognitoFormId)}
                variant="upcoming"
              />
            </li>
          ))}
        </ul>
      )
    }
  </section>

  <!-- ============================================================
       PAST EVENTS
       ============================================================ -->
  {
    past.length > 0 && (
      <section
        class="py-12 md:py-16 px-4 max-w-7xl mx-auto border-t border-gray-200 dark:border-gray-700"
        aria-labelledby="past-heading"
      >
        <h2 id="past-heading" class="font-heading text-3xl md:text-4xl font-bold text-heading mb-8 text-muted">
          {eventsListSettings.pastHeading}
        </h2>
        <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 list-none p-0 m-0" role="list">
          {past.map((event: (typeof past)[0]) => (
            <li>
              <EventCard
                title={event.data.title}
                date={formatEventDateRange(event.data.date, event.data.endDate)}
                location={event.data.location}
                href={`/events/${event.id}`}
                image={event.data.image}
                variant="past"
              />
            </li>
          ))}
        </ul>
      </section>
    )
  }
</Layout>
