---
import { getCollection, type CollectionEntry } from 'astro:content';
import { getImage } from 'astro:assets';
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import CognitoForm from '~/components/widgets/CognitoForm.astro';
import Image from '~/components/common/Image.astro';
import { findImage } from '~/utils/images';
import siteSettings from '~/data/settings/site.json';
import { groupClassesByPeriod } from '~/utils/classes';
import { computeEventSections } from '~/utils/eventSections';

export async function getStaticPaths() {
  const events = await getCollection('event');
  return events.map((event) => ({
    params: { id: event.id },
    props: { event },
  }));
}

interface Props {
  event: CollectionEntry<'event'>;
}

const { event } = Astro.props;
const { data } = event;

const allLeaders = await getCollection('leader');
const leaderMap = new Map<string, CollectionEntry<'leader'>['data']>(allLeaders.map((l) => [l.id, l.data]));

const linkedLeaderIds = [...new Set((data.classes ?? []).map((c) => c.leaderId).filter((id): id is string => !!id))];

const UTC: Intl.DateTimeFormatOptions = { timeZone: 'UTC' };

function escapeHtml(str: string): string {
  return str
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric', ...UTC });
}

function formatDateRange(data: Props['event']['data']) {
  const opts = { month: 'long' as const, day: 'numeric' as const, year: 'numeric' as const, ...UTC };
  const start = data.date.toLocaleDateString('en-US', opts);
  if (!data.endDate) return start;
  const sm = data.date.toLocaleDateString('en-US', { month: 'long', ...UTC });
  const em = data.endDate.toLocaleDateString('en-US', { month: 'long', ...UTC });
  const sy = data.date.toLocaleDateString('en-US', { year: 'numeric', ...UTC });
  const ey = data.endDate.toLocaleDateString('en-US', { year: 'numeric', ...UTC });
  if (sm === em && sy === ey) {
    const d1 = data.date.toLocaleDateString('en-US', { day: 'numeric', ...UTC });
    const d2 = data.endDate.toLocaleDateString('en-US', { day: 'numeric', ...UTC });
    return `${sm} ${d1}–${d2}, ${sy}`;
  }
  return `${start} – ${data.endDate.toLocaleDateString('en-US', opts)}`;
}

// en-CA produces YYYY-MM-DD output (the only locale that does), which lets us
// concatenate directly into a valid ISO string. The timezone is what matters here.
const nowET = new Date(new Date().toLocaleDateString('en-CA', { timeZone: 'America/New_York' }) + 'T00:00:00Z');
const { isPast, pricingRows, jumpLinks, showJumpNav, cancellationCutoff } = computeEventSections(data, nowET);

type PricingTier = NonNullable<typeof data.pricing>[0];
const pricingNotes: PricingTier[] = (data.pricing ?? []).filter((p) => p.note);

function formatCutoff(d: Date) {
  return d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
}
const eventTags: string[] = data.tags ?? [];

// Keep draft events and e2e test fixtures out of the search index, mirroring
// the sitemap (astro.config.ts) and listing exclusions.
const noIndex = data.draft === true || event.id.startsWith('e2e-');

// Resolve the event image (possibly a `~/assets/...` ref) to an optimized,
// absolute URL for structured data. OpenGraph is handled separately by
// adaptOpenGraphImages, which resolves `~/assets/...` on its own.
const resolvedImage = await findImage(data.image);
let socialImageUrl: string | undefined;
if (resolvedImage && typeof resolvedImage === 'object') {
  const og = await getImage({ src: resolvedImage, width: 1200, height: 630, format: 'jpg' });
  socialImageUrl = Astro.site ? new URL(og.src, Astro.site).href : og.src;
} else if (typeof resolvedImage === 'string') {
  socialImageUrl = Astro.site ? new URL(resolvedImage, Astro.site).href : resolvedImage;
}

const metadata = {
  title: data.title,
  description: data.excerpt ?? `${data.title} — ${formatDateRange(data)} at ${data.location}`,
  openGraph: { images: [{ url: `/og/${event.id}.jpg`, width: 1200, height: 630 }] },
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: data.title,
  startDate: data.date.toISOString(),
  endDate: data.endDate?.toISOString() ?? data.date.toISOString(),
  eventStatus: isPast ? 'https://schema.org/EventPast' : 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  location: {
    '@type': 'Place',
    name: data.location,
    address: data.address ?? data.location,
  },
  description: data.excerpt ?? data.description,
  image: socialImageUrl ? [socialImageUrl] : undefined,
  url: String(Astro.url),
  organizer: {
    '@type': 'Organization',
    name: 'ECRS',
    url: Astro.site ? String(Astro.site) : undefined,
  },
  offers:
    pricingRows.length > 0
      ? pricingRows.map((p) => ({
          '@type': 'Offer',
          name: p.ageRange,
          price: p.fullWeekend === 'Free' ? '0' : (p.fullWeekend?.replace(/[^0-9.]/g, '') ?? '0'),
          priceCurrency: 'USD',
          availability: isPast ? 'https://schema.org/SoldOut' : 'https://schema.org/InStock',
          url: data.registrationUrl ?? String(Astro.url),
        }))
      : undefined,
};
---

<Layout metadata={metadata} noIndex={noIndex}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============================================================
       EVENT HERO
       ============================================================ -->
  <section class="relative not-prose" aria-label={data.title}>
    {
      data.image && (
        <div class="relative w-full h-[40vh] overflow-hidden" aria-hidden="true">
          <Image
            src={data.image}
            alt={data.title}
            width={1200}
            height={600}
            widths={[640, 960, 1200, 1600]}
            sizes="100vw"
            layout="cover"
            class="w-full h-full object-cover"
            loading="eager"
            fetchpriority="high"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent" />
        </div>
      )
    }

    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-10 md:py-14">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-2 text-sm text-muted list-none p-0 m-0">
          <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
          <li aria-hidden="true" class="text-muted/50">›</li>
          <li><a href="/events" class="hover:text-primary transition-colors">Events</a></li>
          <li aria-hidden="true" class="text-muted/50">›</li>
          <li aria-current="page" class="text-default min-w-0 truncate">{data.title}</li>
        </ol>
      </nav>

      <!-- Status badge -->
      {
        isPast && (
          <span class="inline-block mb-4 px-3 py-1 text-xs font-bold uppercase tracking-widest rounded-full bg-gray-200 text-gray-600 dark:bg-gray-700 dark:text-gray-300">
            Past Event
          </span>
        )
      }

      <div class="flex items-start gap-3 mb-6">
        <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold text-heading leading-tight flex-1">
          {data.title}
        </h1>
        <button
          id="share-btn"
          class="mt-2 shrink-0 p-2 rounded-full text-muted hover:text-primary hover:bg-primary/10 transition-colors cursor-pointer"
          data-title={data.title}
          data-text={data.excerpt ?? `${data.title} — ${formatDateRange(data)} at ${data.location}`}
          aria-label="Share this event"
        >
          <svg
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            ><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"
            ></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line
              x1="15.41"
              y1="6.51"
              x2="8.59"
              y2="10.49"></line></svg
          >
        </button>
      </div>

      <!-- Event meta -->
      <div class="grid sm:grid-cols-2 gap-4 mb-8">
        <a
          href={`/events/${event.id}.ics`}
          class="flex gap-3 items-start rounded-xl p-2 -m-2 hover:bg-primary/5 transition-colors group"
        >
          <span class="text-primary mt-0.5 flex-shrink-0" aria-hidden="true">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"
              ></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg
            >
          </span>
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-muted">Date</p>
            <p class="text-default font-semibold group-hover:underline">{formatDateRange(data)}</p>
            {
              (data.startTime || data.endTime) && (
                <p class="text-sm text-muted">
                  {data.startTime && `Starts ${data.startTime}`}
                  {data.startTime && data.endTime && ' · '}
                  {data.endTime && `Ends ${data.endTime}`}
                </p>
              )
            }
          </div>
        </a>

        <a
          href={`geo:0,0?q=${encodeURIComponent([data.location, data.address].filter(Boolean).join(', '))}`}
          data-maps-fallback={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent([data.location, data.address].filter(Boolean).join(', '))}`}
          class="flex gap-3 items-start rounded-xl p-2 -m-2 hover:bg-primary/5 transition-colors group"
        >
          <span class="text-primary mt-0.5 flex-shrink-0" aria-hidden="true">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"
              ></circle></svg
            >
          </span>
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-muted">Location</p>
            <p class="text-default font-semibold group-hover:underline">{data.location}</p>
            {data.address && <p class="text-sm text-muted">{data.address}</p>}
            {data.phone && <p class="text-sm text-muted">{data.phone}</p>}
          </div>
        </a>

        {
          data.earlyBirdDeadline && !isPast && (
            <div class="flex gap-3 items-start">
              <span class="text-secondary mt-0.5 flex-shrink-0" aria-hidden="true">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <>
                    <circle cx="12" cy="12" r="10" />
                    <path d="M12 6v6l4 2" />
                  </>
                </svg>
              </span>
              <div>
                <p class="text-xs font-bold uppercase tracking-widest text-muted">Early-bird deadline</p>
                <p class="text-secondary font-semibold">{formatDate(data.earlyBirdDeadline)}</p>
                {data.earlyBirdFeeNote && <p class="text-sm text-muted">{data.earlyBirdFeeNote}</p>}
              </div>
            </div>
          )
        }

        {
          data.registrationDeadline && !isPast && (
            <div class="flex gap-3 items-start">
              <span class="text-secondary mt-0.5 flex-shrink-0" aria-hidden="true">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <>
                    <circle cx="12" cy="12" r="10" />
                    <polyline points="12 6 12 12 16 14" />
                  </>
                </svg>
              </span>
              <div>
                <p class="text-xs font-bold uppercase tracking-widest text-muted">Register by</p>
                <p class="text-secondary font-semibold">{formatDate(data.registrationDeadline)}</p>
              </div>
            </div>
          )
        }
        {
          data.accessibilityNote && (
            <div class="flex gap-3 items-start">
              <span class="text-primary mt-0.5 flex-shrink-0" aria-hidden="true">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <>
                    <circle cx="12" cy="12" r="10" />
                    <path d="M12 8v4m0 4h.01" />
                  </>
                </svg>
              </span>
              <div>
                <p class="text-xs font-bold uppercase tracking-widest text-muted">Accessibility</p>
                <p class="text-default text-sm">{data.accessibilityNote}</p>
              </div>
            </div>
          )
        }
      </div>

      <!-- Action buttons -->
      <div class="flex flex-wrap gap-4 mb-10">
        {
          !isPast && data.cognitoFormId && (
            <a href="#registration" class="btn btn-primary">
              Register Now
            </a>
          )
        }
        {
          !isPast && !data.cognitoFormId && data.registrationUrl && (
            <a href={data.registrationUrl} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
              Register Now
            </a>
          )
        }
        {
          !isPast && (
            <a href={`/events/${event.id}.ics`} class="btn btn-secondary">
              Add to Calendar
            </a>
          )
        }
        <a href="/events" class="btn btn-secondary">← All Events</a>
      </div>

      <!-- Jump nav -->
      {
        showJumpNav && (
          <nav aria-label="Jump to section" class="flex flex-wrap gap-2 mb-8">
            {jumpLinks.map((link) => (
              <a
                href={link.href}
                class="text-sm font-semibold text-primary border border-primary/30 rounded-full px-3 py-1 hover:bg-primary/5 transition-colors"
              >
                {link.label} ↓
              </a>
            ))}
          </nav>
        )
      }

      <!-- Description -->
      {
        data.description && (
          <div class="prose prose-lg dark:prose-invert max-w-none">
            <Fragment set:html={escapeHtml(data.description).replace(/\n/g, '<br>')} />
          </div>
        )
      }

      <!-- ── Simple fee ── -->
      {
        data.fee && (
          <div id="costs" class="mt-10 scroll-mt-24">
            <h2 class="font-heading text-2xl font-bold text-heading mb-3">Cost</h2>
            <p class="text-lg text-default">{data.fee}</p>
          </div>
        )
      }

      <!-- ── Tuition ── -->
      {
        data.tuition && data.tuition.length > 0 && (
          <div id={!data.fee ? 'costs' : undefined} class={!data.fee ? 'mt-10 scroll-mt-24' : 'mt-10'}>
            <h2 class="font-heading text-2xl font-bold text-heading mb-4">{data.tuitionLabel ?? 'Tuition'}</h2>
            {data.tuition.length === 1 ? (
              <div class="inline-flex flex-col gap-0.5 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 px-6 py-4">
                <span class="text-2xl font-bold text-heading">{data.tuition[0].amount}</span>
                {data.tuition[0].label && <span class="text-sm text-muted">{data.tuition[0].label}</span>}
                {data.tuition[0].note && <span class="text-xs text-muted italic mt-1">{data.tuition[0].note}</span>}
              </div>
            ) : (
              (() => {
                const hasLabels = data.tuition!.some((t) => t.label);
                return (
                  <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-700">
                    <table class="w-full text-sm">
                      <thead>
                        <tr class="bg-gray-50 dark:bg-gray-800">
                          {hasLabels && (
                            <th scope="col" class="text-left px-4 py-3 font-semibold text-heading">
                              Category
                            </th>
                          )}
                          <th scope="col" class="text-left px-4 py-3 font-semibold text-heading">
                            Amount
                          </th>
                        </tr>
                      </thead>
                      <tbody>
                        {data.tuition!.map((tier, i) => (
                          <tr
                            class:list={[
                              'border-t border-gray-200 dark:border-gray-700',
                              { 'bg-gray-50 dark:bg-gray-900': i % 2 === 0 },
                            ]}
                          >
                            {hasLabels && (
                              <td class="px-4 py-3">
                                {tier.label && <span>{tier.label}</span>}
                                {tier.note && <span class="block text-xs text-muted italic mt-0.5">{tier.note}</span>}
                              </td>
                            )}
                            <td class="px-4 py-3 font-semibold">{tier.amount}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                );
              })()
            )}
          </div>
        )
      }

      <!-- ── Accommodations (room & board) ── -->
      {
        data.accommodations && data.accommodations.length > 0 && (
          <div class="mt-10">
            <h2 class="font-heading text-2xl font-bold text-heading mb-6">Room &amp; Board</h2>
            <div class="space-y-8">
              {data.accommodations.map((accom) => (
                <div>
                  <h3 class="font-heading text-lg font-bold text-heading mb-1">{accom.name}</h3>
                  {accom.description && <p class="text-sm text-muted mb-3">{accom.description}</p>}
                  <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-700">
                    <table class="w-full text-sm">
                      <thead>
                        <tr class="bg-gray-50 dark:bg-gray-800">
                          <th scope="col" class="text-left px-4 py-3 font-semibold text-heading">
                            Occupancy
                          </th>
                          <th scope="col" class="text-left px-4 py-3 font-semibold text-heading">
                            Per Person
                          </th>
                        </tr>
                      </thead>
                      <tbody>
                        {accom.tiers.map((tier, i) => (
                          <tr
                            class:list={[
                              'border-t border-gray-200 dark:border-gray-700',
                              { 'bg-gray-50 dark:bg-gray-900': i % 2 === 0 },
                            ]}
                          >
                            <td class="px-4 py-3">{tier.label}</td>
                            <td class="px-4 py-3 font-semibold">{tier.amount}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )
      }

      <!-- ── Legacy pricing table (back-compat) ── -->
      {
        pricingRows.length > 0 && (
          <div class="mt-10">
            <h2 class="font-heading text-2xl font-bold text-heading mb-4">Pricing</h2>
            <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-700">
              <table class="w-full text-sm">
                <thead>
                  <tr class="bg-gray-50 dark:bg-gray-800">
                    <th scope="col" class="text-left px-4 py-3 font-semibold text-heading">
                      Age Range
                    </th>
                    <th scope="col" class="text-left px-4 py-3 font-semibold text-heading">
                      Full Weekend
                    </th>
                  </tr>
                </thead>
                <tbody>
                  {pricingRows.map((tier, i) => (
                    <tr
                      class:list={[
                        'border-t border-gray-200 dark:border-gray-700',
                        { 'bg-gray-50 dark:bg-gray-900': i % 2 === 0 },
                      ]}
                    >
                      <td class="px-4 py-3">{tier.ageRange}</td>
                      <td class="px-4 py-3 font-semibold">{tier.fullWeekend ?? '—'}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            {pricingNotes.map((p) => (
              <p class="text-sm text-muted mt-3 italic">{p.note}</p>
            ))}
          </div>
        )
      }

      <!-- ── Meals ── -->
      {
        (data.mealsIncluded || data.mealsNote) && (
          <div class="mt-10">
            <h2 class="font-heading text-2xl font-bold text-heading mb-3">Meals</h2>
            {data.mealsIncluded && <p class="text-default font-semibold">{data.mealsIncluded}</p>}
            {data.mealsNote && <p class="text-sm text-muted mt-1">{data.mealsNote}</p>}
          </div>
        )
      }

      <!-- ── Classes / program ── -->
      {
        data.classes &&
          data.classes.length > 0 &&
          (() => {
            const groups = groupClassesByPeriod(data.classes!);
            const isFlat = groups.size === 1 && groups.has('');
            const isMultiDay = !!data.endDate;
            return (
              <div id="classes" class="mt-10 scroll-mt-24">
                <h2 class="font-heading text-2xl font-bold text-heading mb-6">Classes</h2>
                <div class="space-y-8">
                  {[...groups.entries()].map(([period, classes]) => (
                    <div>
                      {!isFlat && period && (
                        <h3 class="font-heading text-base font-bold uppercase tracking-widest text-muted mb-3">
                          {period}
                        </h3>
                      )}
                      <ul class="space-y-3 list-none p-0 m-0">
                        {classes.map((cls) => (
                          <li class="rounded-xl border border-gray-200 dark:border-gray-700 px-4 py-3">
                            <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
                              <span class="font-semibold text-heading">{cls.name}</span>
                              {(() => {
                                const record = cls.leaderId ? leaderMap.get(cls.leaderId) : null;
                                const name = record?.name ?? cls.leader;
                                const photo = record?.photo;
                                if (!name) return null;
                                if (record) {
                                  return (
                                    <span class="inline-flex items-center gap-1.5 text-sm text-muted">
                                      —
                                      {photo && (
                                        <Image
                                          src={photo}
                                          alt={name}
                                          width={20}
                                          height={20}
                                          widths={[20, 40]}
                                          sizes="20px"
                                          layout="cover"
                                          class="w-5 h-5 rounded-full object-cover"
                                        />
                                      )}
                                      <button
                                        type="button"
                                        data-popover-target={`leader-${cls.leaderId}`}
                                        aria-controls={`leader-${cls.leaderId}`}
                                        aria-expanded="false"
                                        class="underline decoration-dotted underline-offset-2 cursor-pointer hover:text-primary transition-colors"
                                      >
                                        {name}
                                      </button>
                                    </span>
                                  );
                                }
                                return (
                                  <span class="inline-flex items-center gap-1.5 text-sm text-muted">— {name}</span>
                                );
                              })()}
                              {cls.ageRange && (
                                <span class="text-xs font-semibold text-muted border border-muted/30 rounded-full px-2 py-0.5">
                                  {cls.ageRange}
                                </span>
                              )}
                              {isMultiDay && cls.days && <span class="text-xs text-muted">{cls.days}</span>}
                              {cls.limitedCapacity && (
                                <span class="text-xs font-semibold text-amber-600 dark:text-amber-400 border border-amber-300 dark:border-amber-600 rounded-full px-2 py-0.5">
                                  Limited capacity
                                </span>
                              )}
                            </div>
                            {cls.description && <p class="text-sm text-muted mt-1">{cls.description}</p>}
                            {cls.callout && <p class="text-sm font-semibold text-primary mt-1">{cls.callout}</p>}
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </div>
              </div>
            );
          })()
      }

      <!-- ── Newcomer / financial aid / leader profiles ── -->
      {
        (data.newcomerNote || data.financialAidNote) && (
          <div class="mt-10 flex flex-col gap-3">
            {data.newcomerNote && (
              <p class="text-sm text-default bg-primary/5 rounded-xl px-4 py-3">
                <span class="font-semibold">New to ECRS?</span> {data.newcomerNote}
              </p>
            )}
            {data.financialAidNote && (
              <p class="text-sm text-default bg-accent/5 rounded-xl px-4 py-3">
                <span class="font-semibold">Financial assistance:</span> {data.financialAidNote}
              </p>
            )}
            <p class="text-sm text-default">
              <a href="/our-people" class="text-primary hover:underline font-semibold">
                View leader &amp; staff profiles →
              </a>
            </p>
          </div>
        )
      }

      <!-- ── Policies ── -->
      {
        (data.showCancellationPolicy || data.showHealthPolicy) && (
          <div class="mt-10 space-y-6">
            <h2 class="font-heading text-2xl font-bold text-heading">Policies</h2>

            {data.showCancellationPolicy && data.cancellationPolicy && (
              <div class="rounded-xl border border-gray-200 dark:border-gray-700 p-5">
                <h3 class="font-heading text-base font-bold text-heading mb-1">Cancellation</h3>
                {cancellationCutoff && (
                  <p class="text-sm font-semibold text-secondary mb-2">
                    Refund cutoff: {formatCutoff(cancellationCutoff)}
                  </p>
                )}
                <p class="text-sm text-muted whitespace-pre-line">{data.cancellationPolicy}</p>
              </div>
            )}

            {data.showHealthPolicy && data.healthPolicy && (
              <div class="rounded-xl border border-gray-200 dark:border-gray-700 p-5">
                <h3 class="font-heading text-base font-bold text-heading mb-2">Health</h3>
                <p class="text-sm text-muted whitespace-pre-line">{data.healthPolicy}</p>
              </div>
            )}
          </div>
        )
      }

      <!-- Tags -->
      {
        eventTags.length > 0 && (
          <div class="mt-8 flex flex-wrap gap-2" aria-label="Event tags">
            {eventTags.map((tag) => (
              <span class="px-3 py-1 text-xs font-semibold rounded-full bg-accent/10 text-accent dark:bg-accent/20">
                {tag}
              </span>
            ))}
          </div>
        )
      }
    </div>
  </section>

  <!-- ============================================================
       REGISTRATION FORM
       ============================================================ -->
  {
    !isPast && data.cognitoFormId && (
      <div id="registration" class="scroll-mt-24">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-4 pb-2">
          <h2 class="font-heading text-2xl font-bold text-heading">Register</h2>
        </div>
        <CognitoForm formId={data.cognitoFormId} />
      </div>
    )
  }

  <!-- ============================================================
       BOTTOM CTA
       ============================================================ -->
  {
    !isPast && (
      <CallToAction
        title={siteSettings.eventCtaTitle}
        subtitle={siteSettings.eventCtaSubtitle}
        actions={
          data.registrationUrl
            ? [
                { variant: 'primary', text: 'Register Now', href: data.registrationUrl, target: '_blank' },
                { text: 'Contact Us', href: '/contact' },
              ]
            : data.cognitoFormId
              ? [
                  { variant: 'primary', text: 'Register Now', href: '#registration' },
                  { text: 'Contact Us', href: '/contact' },
                ]
              : [
                  { variant: 'primary', text: 'Contact Us', href: '/contact' },
                  { text: 'All Events', href: '/events' },
                ]
        }
      >
        <Fragment slot="bg">
          <div class="absolute inset-0 bg-primary/5 dark:bg-transparent" />
        </Fragment>
      </CallToAction>
    )
  }

  <!-- ── Leader popovers ── -->
  {
    linkedLeaderIds.map((id) => {
      const leader = leaderMap.get(id);
      if (!leader) return null;
      return (
        <div
          id={`leader-${id}`}
          popover="auto"
          class="m-0 p-0 border-0 bg-transparent shadow-none [&::backdrop]:bg-black/20"
        >
          <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 rounded-2xl shadow-xl p-4 w-64 max-w-[calc(100vw-2rem)]">
            <div class="flex items-center gap-3 mb-2">
              {leader.photo && (
                <Image
                  src={leader.photo}
                  alt={leader.name}
                  width={48}
                  height={48}
                  widths={[48, 96]}
                  sizes="48px"
                  layout="cover"
                  class="w-12 h-12 rounded-full object-cover flex-shrink-0"
                />
              )}
              <div class="min-w-0">
                <p class="font-semibold text-gray-900 dark:text-white leading-snug">{leader.name}</p>
                {leader.title && <p class="text-xs text-gray-500 dark:text-gray-400 leading-snug">{leader.title}</p>}
              </div>
            </div>
            {leader.bio && <p class="text-sm text-gray-600 dark:text-gray-300 line-clamp-6 mb-3">{leader.bio}</p>}
            <a href={`/our-people#leader-${id}`} class="text-xs font-semibold text-primary hover:underline">
              View full profile →
            </a>
          </div>
        </div>
      );
    })
  }
</Layout>

<script>
  function initLeaderPopovers() {
    document.querySelectorAll<HTMLButtonElement>('[data-popover-target]').forEach((btn) => {
      const pop = document.getElementById(btn.dataset.popoverTarget!);
      if (!pop) return;
      let hideTimer: ReturnType<typeof setTimeout>;

      function position() {
        const rect = btn.getBoundingClientRect();
        const card = pop!.querySelector('div')!;
        const margin = 8;
        let left = rect.left;
        let top = rect.bottom + margin;
        if (left + card.offsetWidth > window.innerWidth - margin) left = window.innerWidth - card.offsetWidth - margin;
        if (left < margin) left = margin;
        if (top + card.offsetHeight > window.innerHeight - margin) top = rect.top - card.offsetHeight - margin;
        pop!.style.position = 'fixed';
        pop!.style.left = left + 'px';
        pop!.style.top = top + 'px';
      }

      function show() {
        clearTimeout(hideTimer);
        if (!pop!.matches(':popover-open')) {
          pop!.showPopover();
          position();
          btn.setAttribute('aria-expanded', 'true');
        }
      }

      function hide() {
        hideTimer = setTimeout(() => {
          if (pop!.matches(':popover-open')) {
            pop!.hidePopover();
            btn.setAttribute('aria-expanded', 'false');
          }
        }, 120);
      }

      btn.addEventListener('mouseenter', show);
      btn.addEventListener('mouseleave', hide);
      // Click always shows; outside-click auto-dismisses via popover="auto"
      btn.addEventListener('click', () => show());
      pop.addEventListener('mouseenter', () => clearTimeout(hideTimer));
      pop.addEventListener('mouseleave', hide);
    });
  }

  initLeaderPopovers();
  document.addEventListener('astro:page-load', initLeaderPopovers);

  const shareBtn = document.getElementById('share-btn') as HTMLButtonElement | null;
  if (shareBtn) {
    shareBtn.addEventListener('click', async () => {
      const { title, text } = shareBtn.dataset;
      const url = window.location.href;
      if (navigator.share) {
        await navigator.share({ title, text, url });
      } else {
        await navigator.clipboard.writeText(url);
        const originalHTML = shareBtn.innerHTML;
        shareBtn.innerHTML = '<span class="text-sm font-semibold px-1">Copied!</span>';
        setTimeout(() => (shareBtn.innerHTML = originalHTML), 2000);
      }
    });
  }

  // On mobile, geo: triggers the system app chooser (Google Maps, Waze, Apple Maps, etc.).
  // On desktop, geo: does nothing, so fall back to maps.apple.com which works in any browser.
  document.addEventListener('click', (e) => {
    const link = (e.target as Element).closest('a[data-maps-fallback]') as HTMLAnchorElement | null;
    if (!link) return;
    const isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);
    if (!isMobile) {
      e.preventDefault();
      window.open(link.dataset.mapsFallback, '_blank', 'noopener,noreferrer');
    }
  });
</script>
