---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import CognitoForm from '~/components/widgets/CognitoForm.astro';
import siteSettings from '~/data/settings/site.json';

export async function getStaticPaths() {
  const events = await getCollection('event');
  return events.map((event) => ({
    params: { id: event.id },
    props: { event },
  }));
}

interface Props {
  event: CollectionEntry<'event'>;
}

const { event } = Astro.props;
const { data } = event;

const UTC: Intl.DateTimeFormatOptions = { timeZone: 'UTC' };

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric', ...UTC });
}

function formatDateRange(data: Props['event']['data']) {
  const opts = { month: 'long' as const, day: 'numeric' as const, year: 'numeric' as const, ...UTC };
  const start = data.date.toLocaleDateString('en-US', opts);
  if (!data.endDate) return start;
  const sm = data.date.toLocaleDateString('en-US', { month: 'long', ...UTC });
  const em = data.endDate.toLocaleDateString('en-US', { month: 'long', ...UTC });
  const sy = data.date.toLocaleDateString('en-US', { year: 'numeric', ...UTC });
  const ey = data.endDate.toLocaleDateString('en-US', { year: 'numeric', ...UTC });
  if (sm === em && sy === ey) {
    const d1 = data.date.toLocaleDateString('en-US', { day: 'numeric', ...UTC });
    const d2 = data.endDate.toLocaleDateString('en-US', { day: 'numeric', ...UTC });
    return `${sm} ${d1}–${d2}, ${sy}`;
  }
  return `${start} – ${data.endDate.toLocaleDateString('en-US', opts)}`;
}

const now = new Date();
const isPast = (data.endDate ?? data.date) < now;

type PricingTier = NonNullable<typeof data.pricing>[0];
const pricingRows: PricingTier[] = (data.pricing ?? []).filter((p) => p.ageRange);
const pricingNotes: PricingTier[] = (data.pricing ?? []).filter((p) => p.note);
const eventTags: string[] = data.tags ?? [];

const metadata = {
  title: data.title,
  description: data.excerpt ?? `${data.title} — ${formatDateRange(data)} at ${data.location}`,
  openGraph: data.image ? { images: [{ url: data.image, width: 1200, height: 630 }] } : undefined,
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: data.title,
  startDate: data.date.toISOString(),
  endDate: data.endDate?.toISOString() ?? data.date.toISOString(),
  eventStatus: isPast ? 'https://schema.org/EventScheduled' : 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  location: {
    '@type': 'Place',
    name: data.location,
    address: data.address ?? data.location,
  },
  description: data.excerpt ?? data.description,
  image: data.image ? [Astro.site ? new URL(data.image, Astro.site).href : data.image] : undefined,
  url: String(Astro.url),
  organizer: {
    '@type': 'Organization',
    name: 'ECRS',
    url: Astro.site ? String(Astro.site) : undefined,
  },
  offers:
    pricingRows.length > 0
      ? pricingRows.map((p) => ({
          '@type': 'Offer',
          name: p.ageRange,
          price: p.fullWeekend === 'Free' ? '0' : (p.fullWeekend?.replace(/[^0-9.]/g, '') ?? '0'),
          priceCurrency: 'USD',
          availability: isPast ? 'https://schema.org/SoldOut' : 'https://schema.org/InStock',
          url: data.registrationUrl ?? String(Astro.url),
        }))
      : undefined,
};
---

<Layout metadata={metadata}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- ============================================================
       EVENT HERO
       ============================================================ -->
  <section class="relative not-prose" aria-label={data.title}>
    {
      data.image && (
        <div class="relative w-full h-[40vh] overflow-hidden" aria-hidden="true">
          <img
            src={data.image}
            alt={data.title}
            width="1200"
            height="600"
            class="w-full h-full object-cover"
            loading="eager"
            fetchpriority="high"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent" />
        </div>
      )
    }

    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-10 md:py-14">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-2 text-sm text-muted list-none p-0 m-0">
          <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
          <li aria-hidden="true" class="text-muted/50">›</li>
          <li><a href="/events" class="hover:text-primary transition-colors">Events</a></li>
          <li aria-hidden="true" class="text-muted/50">›</li>
          <li aria-current="page" class="text-default truncate max-w-[200px]">{data.title}</li>
        </ol>
      </nav>

      <!-- Status badge -->
      {
        isPast && (
          <span class="inline-block mb-4 px-3 py-1 text-xs font-bold uppercase tracking-widest rounded-full bg-gray-200 text-gray-600 dark:bg-gray-700 dark:text-gray-300">
            Past Event
          </span>
        )
      }

      <div class="flex items-start gap-3 mb-6">
        <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-bold text-heading leading-tight flex-1">
          {data.title}
        </h1>
        <button
          id="share-btn"
          class="mt-2 shrink-0 p-2 rounded-full text-muted hover:text-primary hover:bg-primary/10 transition-colors cursor-pointer"
          data-title={data.title}
          data-text={data.excerpt ?? `${data.title} — ${formatDateRange(data)} at ${data.location}`}
          aria-label="Share this event"
        >
          <svg
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            ><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"
            ></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line
              x1="15.41"
              y1="6.51"
              x2="8.59"
              y2="10.49"></line></svg
          >
        </button>
      </div>

      <!-- Event meta -->
      <dl class="grid sm:grid-cols-2 gap-4 mb-8">
        <a
          href={`/events/${event.id}.ics`}
          class="flex gap-3 items-start rounded-xl p-2 -m-2 hover:bg-primary/5 transition-colors group"
        >
          <span class="text-primary mt-0.5 flex-shrink-0" aria-hidden="true">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"
              ></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg
            >
          </span>
          <div>
            <dt class="text-xs font-bold uppercase tracking-widest text-muted">Date</dt>
            <dd class="text-default font-semibold group-hover:underline">{formatDateRange(data)}</dd>
            {
              (data.startTime || data.endTime) && (
                <dd class="text-sm text-muted">
                  {data.startTime && `Starts ${data.startTime}`}
                  {data.startTime && data.endTime && ' · '}
                  {data.endTime && `Ends ${data.endTime}`}
                </dd>
              )
            }
          </div>
        </a>

        <a
          href={`geo:0,0?q=${encodeURIComponent([data.location, data.address].filter(Boolean).join(', '))}`}
          data-maps-fallback={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent([data.location, data.address].filter(Boolean).join(', '))}`}
          class="flex gap-3 items-start rounded-xl p-2 -m-2 hover:bg-primary/5 transition-colors group"
        >
          <span class="text-primary mt-0.5 flex-shrink-0" aria-hidden="true">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"
              ></circle></svg
            >
          </span>
          <div>
            <dt class="text-xs font-bold uppercase tracking-widest text-muted">Location</dt>
            <dd class="text-default font-semibold group-hover:underline">{data.location}</dd>
            {data.address && <dd class="text-sm text-muted">{data.address}</dd>}
          </div>
        </a>

        {
          data.registrationDeadline && !isPast && (
            <div class="flex gap-3 items-start">
              <span class="text-secondary mt-0.5 flex-shrink-0" aria-hidden="true">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <>
                    <circle cx="12" cy="12" r="10" />
                    <polyline points="12 6 12 12 16 14" />
                  </>
                </svg>
              </span>
              <div>
                <dt class="text-xs font-bold uppercase tracking-widest text-muted">Register by</dt>
                <dd class="text-secondary font-semibold">{formatDate(data.registrationDeadline)}</dd>
              </div>
            </div>
          )
        }
      </dl>

      <!-- Action buttons -->
      <div class="flex flex-wrap gap-4 mb-10">
        {
          !isPast && data.registrationUrl && (
            <a href={data.registrationUrl} class="btn btn-primary" target="_blank" rel="noopener noreferrer">
              Register Now
            </a>
          )
        }
        {
          !isPast && data.cognitoFormId && !data.registrationUrl && (
            <a href="#registration" class="btn btn-primary">
              Register Now
            </a>
          )
        }
        {
          !isPast && (
            <a href={`/events/${event.id}.ics`} class="btn btn-secondary">
              Add to Calendar
            </a>
          )
        }
        <a href="/events" class="btn btn-secondary">← All Events</a>
      </div>

      <!-- Description -->
      {
        data.description && (
          <div class="prose prose-lg dark:prose-invert max-w-none">
            <Fragment set:html={data.description.replace(/\n/g, '<br>')} />
          </div>
        )
      }

      <!-- Pricing table -->
      {
        data.pricing && data.pricing.length > 0 && (
          <div class="mt-10">
            <h2 class="font-heading text-2xl font-bold text-heading mb-4">Pricing</h2>
            <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-700">
              <table class="w-full text-sm">
                <thead>
                  <tr class="bg-gray-50 dark:bg-gray-800">
                    <th scope="col" class="text-left px-4 py-3 font-semibold text-heading">
                      Age Range
                    </th>
                    <th scope="col" class="text-left px-4 py-3 font-semibold text-heading">
                      Full Weekend
                    </th>
                  </tr>
                </thead>
                <tbody>
                  {pricingRows.map((tier, i) => (
                    <tr
                      class:list={[
                        'border-t border-gray-200 dark:border-gray-700',
                        { 'bg-gray-50 dark:bg-gray-900': i % 2 === 0 },
                      ]}
                    >
                      <td class="px-4 py-3">{tier.ageRange}</td>
                      <td class="px-4 py-3 font-semibold">{tier.fullWeekend ?? '—'}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            {pricingNotes.map((p) => (
              <p class="text-sm text-muted mt-3 italic">{p.note}</p>
            ))}
          </div>
        )
      }

      <!-- Tags -->
      {
        eventTags.length > 0 && (
          <div class="mt-8 flex flex-wrap gap-2" aria-label="Event tags">
            {eventTags.map((tag) => (
              <span class="px-3 py-1 text-xs font-semibold rounded-full bg-accent/10 text-accent dark:bg-accent/20">
                {tag}
              </span>
            ))}
          </div>
        )
      }
    </div>
  </section>

  <!-- ============================================================
       REGISTRATION FORM
       ============================================================ -->
  {
    !isPast && data.cognitoFormId && (
      <div id="registration">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 pt-4 pb-2">
          <h2 class="font-heading text-2xl font-bold text-heading">Register</h2>
        </div>
        <CognitoForm formId={data.cognitoFormId} height={data.cognitoFormHeight ?? '800'} />
      </div>
    )
  }

  <!-- ============================================================
       BOTTOM CTA
       ============================================================ -->
  {
    !isPast && (
      <CallToAction
        title={siteSettings.eventCtaTitle}
        subtitle={siteSettings.eventCtaSubtitle}
        actions={
          data.registrationUrl
            ? [
                { variant: 'primary', text: 'Register Now', href: data.registrationUrl, target: '_blank' },
                { text: 'Contact Us', href: '/contact' },
              ]
            : data.cognitoFormId
              ? [
                  { variant: 'primary', text: 'Register Now', href: '#registration' },
                  { text: 'Contact Us', href: '/contact' },
                ]
              : [
                  { variant: 'primary', text: 'Contact Us', href: '/contact' },
                  { text: 'All Events', href: '/events' },
                ]
        }
      >
        <Fragment slot="bg">
          <div class="absolute inset-0 bg-primary/5 dark:bg-transparent" />
        </Fragment>
      </CallToAction>
    )
  }
</Layout>

<script>
  const shareBtn = document.getElementById('share-btn') as HTMLButtonElement | null;
  if (shareBtn) {
    shareBtn.addEventListener('click', async () => {
      const { title, text } = shareBtn.dataset;
      const url = window.location.href;
      if (navigator.share) {
        await navigator.share({ title, text, url });
      } else {
        await navigator.clipboard.writeText(url);
        const originalHTML = shareBtn.innerHTML;
        shareBtn.innerHTML = '<span class="text-sm font-semibold px-1">Copied!</span>';
        setTimeout(() => (shareBtn.innerHTML = originalHTML), 2000);
      }
    });
  }

  // On mobile, geo: triggers the system app chooser (Google Maps, Waze, Apple Maps, etc.).
  // On desktop, geo: does nothing, so fall back to maps.apple.com which works in any browser.
  document.addEventListener('click', (e) => {
    const link = (e.target as Element).closest('a[data-maps-fallback]') as HTMLAnchorElement | null;
    if (!link) return;
    const isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);
    if (!isMobile) {
      e.preventDefault();
      window.open(link.dataset.mapsFallback, '_blank', 'noopener,noreferrer');
    }
  });
</script>
