---
import CognitoForm from '~/components/widgets/CognitoForm.astro';
import Features2 from '~/components/widgets/Features2.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Layout from '~/layouts/PageLayout.astro';
import membershipSettings from '~/data/settings/membership.json';

const metadata = {
  title: membershipSettings.heroTitle,
  description:
    'Join the Eastern Cooperative Recreation School and enjoy members-only discounts, voting rights, our newsletter ECHOES, and more.',
};
---

<Layout metadata={metadata}>
  <HeroText tagline={membershipSettings.heroTagline} title={membershipSettings.heroTitle} />

  <Features2 title={membershipSettings.benefitsTitle} columns={2} items={membershipSettings.benefits}>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-orange-100 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- Pricing -->
  <section id="pricing" class="py-12 px-4 max-w-4xl mx-auto">
    <h2 class="text-3xl font-bold text-center mb-4 text-default">{membershipSettings.pricingTitle}</h2>
    <p class="text-center text-muted mb-10 max-w-2xl mx-auto">{membershipSettings.pricingIntro}</p>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
      {
        membershipSettings.pricingTiers.map((tier) => (
          <div
            class:list={[
              'rounded-xl p-6',
              tier.featured
                ? 'border-2 border-primary bg-orange-100 dark:bg-slate-700'
                : 'border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-slate-800',
            ]}
          >
            <h3 class="font-semibold text-lg mb-1 text-default">{tier.title}</h3>
            <p class="text-muted text-sm mb-4">{tier.subtitle}</p>
            <p class="text-4xl font-bold text-primary">{tier.price}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Cognito Forms embed -->
  <section id="membership-form" class="py-8 px-4 max-w-3xl mx-auto">
    <h2 class="text-2xl font-bold text-center mb-6 text-default">{membershipSettings.formHeading}</h2>
    <p class="text-center text-muted mb-4">
      {membershipSettings.formNote}{' '}
      <a href={`mailto:${membershipSettings.formNoteEmail}`} class="text-link">{membershipSettings.formNoteEmail}</a>
    </p>
  </section>
  <CognitoForm formId={membershipSettings.cognitoFormId} formName="membership" id="join" />
</Layout>
