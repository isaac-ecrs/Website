---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import MemberHeatmap from '~/components/widgets/MemberHeatmap';
import memberLocations from '~/data/member-locations.json';

const metadata = {
  title: 'Our Reach',
  description: 'People come from all over to dance, play, and sing together!',
  robots: { index: true, follow: true },
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Our Community"
    title="ECRS Members Across the Map"
    subtitle="Our members come from all over North America. Wherever you live, you belong here."
  />

  <section class="py-8 px-4 max-w-4xl mx-auto">
    <MemberHeatmap cities={memberLocations.cities} maskSmallCounts client:load />
  </section>
</Layout>
