---
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Layout from '~/layouts/PageLayout.astro';
import aboutSettings from '~/data/settings/about.json';

const metadata = {
  title: aboutSettings.heroTitle,
  description: aboutSettings.introText,
};
---

<Layout metadata={metadata}>
  <HeroText tagline={aboutSettings.heroTagline} title={aboutSettings.heroTitle} />

  <Content image={{ src: aboutSettings.introImage, alt: aboutSettings.introImageAlt }}>
    <Fragment slot="content">{aboutSettings.introText}</Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-orange-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <Features2 title="" columns={2} items={aboutSettings.pillars}>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-orange-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <CallToAction
    title={aboutSettings.ctaTitle}
    subtitle={aboutSettings.ctaSubtitle}
    actions={[
      { text: aboutSettings.ctaPrimaryText, href: aboutSettings.ctaPrimaryHref, variant: 'primary' },
      { text: aboutSettings.ctaSecondaryText, href: aboutSettings.ctaSecondaryHref, variant: 'secondary' },
    ]}
  />
</Layout>
