---
import { readdirSync, existsSync } from 'node:fs';
import { join } from 'node:path';
import { getCollection, getEntry } from 'astro:content';
import Layout from '~/layouts/PageLayout.astro';
import VideoHero from '~/components/widgets/VideoHero.astro';
import Features from '~/components/widgets/Features.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Content from '~/components/widgets/Content.astro';
import Image from '~/components/common/Image.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { formatEventDateRange } from '~/utils/dates';

// --- Hero videos: lead clip rotates by calendar day so visitors see variety across builds.
const videoDir = join(process.cwd(), 'public/videos');

const heroVideos = (() => {
  try {
    const clips = readdirSync(videoDir)
      .filter((f) => f.endsWith('.webm'))
      .sort() // stable alphabetical order makes the day-based rotation predictable
      .map((f) => {
        const base = f.replace('.webm', '');
        const webpPoster = `${base}-poster.webp`;
        const jpgPoster = `${base}-poster.jpg`;
        const poster = existsSync(join(videoDir, webpPoster))
          ? `/videos/${webpPoster}`
          : existsSync(join(videoDir, jpgPoster))
            ? `/videos/${jpgPoster}`
            : undefined;
        return {
          webm: `/videos/${f}`,
          mp4: `/videos/${f.replace('.webm', '.mp4')}`,
          poster,
        };
      });
    const dayIndex = Math.floor(Date.now() / 86_400_000) % clips.length;
    return [...clips.slice(dayIndex), ...clips.slice(0, dayIndex)];
  } catch {
    return [];
  }
})();

// --- Data fetching ---
const landingEntry = await getEntry('landingSettings', 'landing');
const testimonials = await getCollection('testimonial');
const landing = landingEntry?.data;

const allEvents = await getCollection('event', ({ data }) => !data.draft);
// en-CA produces YYYY-MM-DD output (the only locale that does), which lets us
// concatenate directly into a valid ISO string. The timezone is what matters here.
const now = new Date(new Date().toLocaleDateString('en-CA', { timeZone: 'America/New_York' }) + 'T00:00:00Z');
const upcomingAll = allEvents
  .filter((e) => (e.data.endDate ?? e.data.date) >= now)
  .sort((a, b) => a.data.date.getTime() - b.data.date.getTime());

const featuredEvent = upcomingAll[0];
const upcomingEvents = upcomingAll.slice(1, 4);

const featuredDateStr = featuredEvent ? formatEventDateRange(featuredEvent.data.date, featuredEvent.data.endDate) : '';

const metadata = {
  title: 'ECRS — Come to Play. Play to Learn.',
  ignoreTitleTemplate: true,
  description:
    landing?.heroSubtitle ??
    'An intergenerational organization providing creative and engaging activities that are fun, develop leadership and build community.',
};
---

<Layout metadata={metadata}>
  <!-- ============================================================
       HERO — full-bleed cycling video background
       ============================================================ -->
  <VideoHero
    videos={heroVideos}
    title={landing?.heroTitle ?? 'Come to Play. Play to Learn.'}
    subtitle={landing?.heroSubtitle ??
      'An intergenerational community for people of all ages — music, dance, games, crafts, and friendship.'}
    badge={featuredEvent ? `Next Event · ${featuredDateStr}` : undefined}
    eventCard={featuredEvent
      ? {
          label: 'Upcoming Event',
          title: featuredEvent.data.title,
          date: featuredDateStr,
          location: featuredEvent.data.location,
          deadline: featuredEvent.data.registrationDeadline
            ? `Register by ${featuredEvent.data.registrationDeadline.toLocaleDateString('en-US', { month: 'long', day: 'numeric', timeZone: 'UTC' })}`
            : undefined,
          image: featuredEvent.data.image,
          dateISO: featuredEvent.data.date.toISOString(),
          hasRegistration: !!(featuredEvent.data.registrationUrl || featuredEvent.data.cognitoFormId),
        }
      : undefined}
    eventHref={featuredEvent ? `/events/${featuredEvent.id}` : undefined}
    primaryCta={featuredEvent ? undefined : { text: 'See Upcoming Events', href: '/events' }}
    secondaryCta={featuredEvent ? { text: 'All Events', href: '/events' } : { text: 'Who We Are', href: '#who-we-are' }}
  />

  <!-- ============================================================
       WHAT TO EXPECT
       ============================================================ -->
  <Features
    id="what-to-expect"
    title={landing?.whatToExpectTitle ?? 'What to Expect'}
    subtitle={landing?.whatToExpectSubtitle ?? ''}
    columns={3}
    items={(landing?.whatToExpectItems ?? []).map((item) => ({
      title: item.title,
      description: item.description,
      icon: item.icon,
      classes: item.iconColor ? { icon: item.iconColor } : undefined,
    }))}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-gray-50 dark:bg-transparent"></div>
    </Fragment>
  </Features>

  <!-- ============================================================
       TESTIMONIALS
       ============================================================ -->
  <Testimonials testimonials={testimonials} />

  <!-- ============================================================
       WHO WE ARE
       ============================================================ -->
  <Content
    id="who-we-are"
    title={landing?.aboutTitle ?? 'Who We Are'}
    image={{
      src: landing?.aboutImage ?? '~/assets/images/ecrs-line-dance.jpg',
      alt: 'ECRS community members line dancing together',
    }}
    callToAction={{
      variant: 'secondary',
      text: 'Learn more about ECRS',
      href: '/about',
    }}
  >
    <Fragment slot="content">
      {
        landing?.aboutBody ??
          'ECRS has been building intergenerational community for over 85 years through the arts and play.'
      }
    </Fragment>
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-gray-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- ============================================================
       VALUE PILLARS
       ============================================================ -->
  <Features
    id="what-we-do"
    title={landing?.whyTitle ?? 'Why ECRS?'}
    subtitle={landing?.whySubtitle ?? ''}
    columns={2}
    items={landing?.pillars ?? [
      {
        title: 'Play & Games',
        description: 'Cooperative games and outdoor activities that bring out the joy in every participant.',
        icon: 'tabler:confetti',
      },
      {
        title: 'Build Community',
        description: 'Over 85 years of creating lasting friendships across generations, backgrounds, and geographies.',
        icon: 'tabler:heart-handshake',
      },
      {
        title: 'Creative Arts',
        description: 'Singing, dancing, dramatics, and crafts — no experience needed. We learn by doing, together.',
        icon: 'tabler:music',
      },
      {
        title: 'Intergenerational',
        description:
          'Events welcome everyone from toddlers to elders. When generations play together, community is built.',
        icon: 'tabler:users-group',
      },
    ]}
  />

  <!-- ============================================================
       KEY STATS
       ============================================================ -->
  {
    landing?.stats && landing.stats.length > 0 && (
      <Stats stats={landing.stats}>
        <Fragment slot="bg">
          <div class="absolute inset-0 bg-pink-50 dark:bg-transparent" />
        </Fragment>
      </Stats>
    )
  }

  <!-- ============================================================
       MORE UPCOMING EVENTS
       ============================================================ -->
  {
    upcomingEvents.length > 0 && (
      <div id="more-events" class="py-16 md:py-20 px-4 max-w-7xl mx-auto">
        <div class="text-center mb-12">
          <p class="text-base font-bold uppercase tracking-widest text-primary mb-2">
            {landing?.moreEventsEyebrow ?? 'Join Us'}
          </p>
          <h2 class="font-heading text-4xl md:text-5xl font-bold text-heading">
            {landing?.moreEventsHeading ?? 'More Upcoming Events'}
          </h2>
        </div>
        <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 list-none p-0 m-0" role="list">
          {upcomingEvents.map((event: (typeof upcomingEvents)[0]) => (
            <li>
              <a
                href={`/events/${event.id}`}
                class="group flex flex-col h-full rounded-2xl border border-gray-200 dark:border-gray-700 overflow-hidden hover:shadow-lg hover:border-primary/40 transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
              >
                {event.data.image && (
                  <Image
                    src={event.data.image}
                    alt=""
                    width={600}
                    height={300}
                    widths={[400, 600, 800]}
                    sizes="(max-width: 768px) 100vw, 400px"
                    layout="cover"
                    class="w-full h-44 object-cover"
                    loading="lazy"
                  />
                )}
                <div class="flex flex-col flex-1 p-5">
                  <p class="text-xs font-bold uppercase tracking-widest text-primary mb-1">
                    {formatEventDateRange(event.data.date, event.data.endDate)}
                  </p>
                  <h3 class="font-heading text-xl font-bold text-heading group-hover:text-primary transition-colors">
                    {event.data.title}
                  </h3>
                  <p class="text-sm text-muted mt-1 mb-3">{event.data.location}</p>
                  {event.data.excerpt && <p class="text-sm text-default line-clamp-3 flex-1">{event.data.excerpt}</p>}
                  <span class="mt-4 text-sm font-semibold text-primary group-hover:underline">
                    {event.data.registrationUrl || event.data.cognitoFormId ? 'Register Now →' : 'Learn More →'}
                  </span>
                </div>
              </a>
            </li>
          ))}
        </ul>
        <div class="text-center mt-10">
          <a href="/events" class="btn btn-secondary">
            {landing?.moreEventsViewAllText ?? 'View all events'}
          </a>
        </div>
      </div>
    )
  }

  <!-- ============================================================
       GET INVOLVED CTA
       ============================================================ -->
  <CallToAction
    title={landing?.ctaTitle ?? 'Ready to join the community?'}
    subtitle={landing?.ctaSubtitle ?? ''}
    actions={[
      {
        variant: 'primary',
        text: landing?.ctaPrimaryText ?? 'See Upcoming Events',
        href: landing?.ctaPrimaryHref ?? '/events',
      },
      { text: landing?.ctaSecondaryText ?? 'Contact Us', href: landing?.ctaSecondaryHref ?? '/contact' },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-primary/5 dark:bg-transparent"></div>
    </Fragment>
  </CallToAction>
</Layout>
