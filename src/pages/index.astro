---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import heroBg from '../assets/images/hero-bg.jpg';

const allEvents = await getCollection('events');
const now = new Date();
const upcomingEvents = allEvents
  .filter((e) => new Date(e.data.endDate) >= now)
  .sort(
    (a, b) =>
      new Date(a.data.startDate).getTime() -
      new Date(b.data.startDate).getTime()
  );

function formatDateRange(start: Date, end: Date): string {
  const sameDay = start.toDateString() === end.toDateString();
  const opts: Intl.DateTimeFormatOptions = { month: 'long', day: 'numeric', year: 'numeric' };
  if (sameDay) return start.toLocaleDateString('en-US', opts);
  if (start.getFullYear() === end.getFullYear()) {
    return `${start.toLocaleDateString('en-US', { month: 'long', day: 'numeric' })} – ${end.toLocaleDateString('en-US', opts)}`;
  }
  return `${start.toLocaleDateString('en-US', opts)} – ${end.toLocaleDateString('en-US', opts)}`;
}
---

<BaseLayout
  title="Home"
  description="ECRS — Come to Play. Play to Learn. Intergenerational folk dance, singing, games, crafts, and more since 1940."
>
  <!-- HERO -->
  <section
    class="hero"
    style={`background-image: url(${heroBg.src})`}
    aria-label="Hero"
  >
    <div class="hero-inner">
      <p class="hero-eyebrow">Eastern Cooperative Recreation School</p>
      <h1 class="hero-headline">Come to Play.<br />Play to Learn.</h1>
      <p class="hero-sub">
        Folk dancing, singing, games, crafts, and connection — for every age,
        since 1940.
      </p>
      {
        upcomingEvents.length > 0 && (
          <a
            href={`/events/${upcomingEvents[0].data.eventSlug}`}
            class="btn btn--primary"
          >
            Next Event: {upcomingEvents[0].data.title} →
          </a>
        )
      }
    </div>
  </section>

  <!-- WHAT IS ECRS -->
  <section class="section section--white" id="about">
    <div class="container about-section">
      <div class="about-text">
        <h2>What is ECRS?</h2>
        <p class="about-lead">
          ECRS is a nonprofit community where people of all ages come to play —
          and discover that play is powerful. At our events you'll sing, dance,
          make things with your hands, play games that actually connect people,
          and share meals with strangers who quickly become friends.
        </p>
        <p>
          We've been doing this since 1940. Our events are intergenerational by
          design: grandparents, parents, kids, and twenty-somethings all in the
          same room, learning from each other. No competition, no performance
          pressure — just shared experience.
        </p>
      </div>
      <div class="activities-grid">
        <div class="activity">🕺 Folk &amp; Line Dancing</div>
        <div class="activity">🎵 Singing &amp; Music</div>
        <div class="activity">🎭 Informal Dramatics</div>
        <div class="activity">🎲 Cooperative Games</div>
        <div class="activity">✂️ Crafts</div>
        <div class="activity">🌱 Personal Growth</div>
      </div>
    </div>
  </section>

  <!-- UPCOMING EVENTS -->
  {
    upcomingEvents.length > 0 && (
      <section class="section section--cream" id="events">
        <div class="container">
          <h2 class="events-heading">Upcoming Events</h2>
          <div class="events-list">
            {upcomingEvents.map((event) => {
              const start = new Date(event.data.startDate);
              const end = new Date(event.data.endDate);
              const dateRange = formatDateRange(start, end);
              return (
                <a
                  href={`/events/${event.data.eventSlug}`}
                  class="event-card"
                >
                  <div class="event-card-meta">
                    <span class="event-date">{dateRange}</span>
                    <span class="event-loc">
                      {event.data.location.venue} &bull;{' '}
                      {event.data.location.city}, {event.data.location.state}
                    </span>
                  </div>
                  <div class="event-card-body">
                    <h3 class="event-title">{event.data.title}</h3>
                    {event.data.shortDescription && (
                      <p class="event-desc">{event.data.shortDescription}</p>
                    )}
                    <div class="event-footer">
                      <span class="event-cost">
                        Cost: {event.data.cost}
                      </span>
                      <span class="event-cta">Details &amp; Registration →</span>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>

<style lang="scss">
  @use '../styles/variables' as *;
  @use '../styles/mixins' as *;

  // ---- HERO ----
  .hero {
    min-height: 100vh;
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    padding-top: var(--header-total-height);

    &::after {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.52);
    }

    @include mobile {
      min-height: 80vh;
      background-attachment: scroll;
    }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    color: white;
    padding: 2em;
    max-width: 760px;
  }

  .hero-eyebrow {
    font-size: 13px;
    font-family: $font-heading;
    text-transform: uppercase;
    letter-spacing: 3px;
    opacity: 0.8;
    margin-bottom: 0.75em;
  }

  .hero-headline {
    font-size: clamp(42px, 8vw, 80px);
    font-family: $font-heading;
    font-weight: $font-weight-bold;
    text-transform: uppercase;
    line-height: 1.05;
    margin-bottom: 0.6em;
    color: white;
  }

  .hero-sub {
    font-size: clamp(16px, 2.5vw, 20px);
    opacity: 0.9;
    margin-bottom: 2em;
    line-height: 1.6;
  }

  // ---- ABOUT ----
  .about-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4em;
    align-items: start;

    @include mobile {
      grid-template-columns: 1fr;
      gap: 2em;
    }
  }

  .about-text {
    h2 {
      color: $color-primary;
      margin-bottom: 0.75em;
    }

    .about-lead {
      font-size: 18px;
      line-height: 1.75;
      margin-bottom: 1.25em;
    }

    p {
      font-size: 16px;
      line-height: 1.75;
      color: rgba($color-text-dark, 0.8);
    }
  }

  .activities-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1em;
    align-self: center;

    @include mobile {
      grid-template-columns: 1fr 1fr;
    }
  }

  .activity {
    background: $color-light-cream;
    border-radius: 6px;
    padding: 1em 1.25em;
    font-size: 15px;
    font-weight: 600;
    color: $color-text-dark;
    border-left: 3px solid $color-accent;
  }

  // ---- EVENTS ----
  .events-heading {
    color: $color-primary;
    margin-bottom: 1.5em;
  }

  .events-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5em;
  }

  .event-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border: 1px solid rgba($color-text-dark, 0.12);
    border-radius: 8px;
    overflow: hidden;
    background: white;
    transition: box-shadow $transition-fast, transform $transition-fast;

    &:hover {
      box-shadow: 0 6px 24px rgba(0, 0, 0, 0.1);
      transform: translateY(-2px);
    }
  }

  .event-card-meta {
    background: $color-primary;
    color: white;
    padding: 0.75em 1.5em;
    display: flex;
    gap: 1.5em;
    align-items: center;
    flex-wrap: wrap;
    font-size: 13px;
    font-family: $font-heading;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .event-date {
    font-weight: $font-weight-bold;
  }

  .event-loc {
    opacity: 0.85;
  }

  .event-card-body {
    padding: 1.5em;
  }

  .event-title {
    color: $color-text-dark;
    font-size: 22px;
    margin-bottom: 0.5em;
    text-transform: none;
  }

  .event-desc {
    color: rgba($color-text-dark, 0.75);
    font-size: 15px;
    line-height: 1.65;
    margin-bottom: 1.25em;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .event-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5em;
    font-size: 14px;
  }

  .event-cost {
    color: $color-text-dark;
    font-weight: 600;
  }

  .event-cta {
    color: $color-primary;
    font-weight: 700;
    font-family: $font-heading;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-size: 13px;
  }
</style>
