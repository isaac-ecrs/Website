---
import { Icon } from 'astro-icon/components';
import type { CollectionEntry } from 'astro:content';

interface Props {
  testimonials: CollectionEntry<'testimonial'>[];
}

const { testimonials } = Astro.props;
---

{
  testimonials.length > 0 && (
    <section class="relative py-12 md:py-16 bg-gray-50 dark:bg-transparent" aria-label="Member testimonials">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <ul id="testimonial-grid" class="grid grid-cols-1 md:grid-cols-3 gap-6 list-none p-0 m-0" role="list">
          {testimonials.map((t, i) => (
            <li
              data-testimonial={i}
              hidden
              class="relative flex flex-col rounded-lg shadow-[0_4px_30px_rgba(0,0,0,0.07)] dark:shadow-[0_4px_30px_rgba(0,0,0,0.15)] backdrop-blur border border-[#ffffff29] bg-white dark:bg-slate-900 p-6"
            >
              <div class="flex-1 flex items-center">
                <blockquote class="text-default italic leading-relaxed">
                  <Icon
                    name="tabler:quote"
                    class="inline w-5 h-5 text-primary/40 mr-1 align-text-top shrink-0"
                    aria-hidden="true"
                  />
                  {t.data.quote}
                </blockquote>
              </div>
              {t.data.name && (
                <footer class="mt-4 text-sm text-muted not-italic">
                  <span class="font-semibold text-heading">{t.data.name}</span>
                  {t.data.role && <span class="block text-xs mt-0.5">{t.data.role}</span>}
                </footer>
              )}
            </li>
          ))}
        </ul>
      </div>
    </section>
  )
}

<script>
  function shuffle<T>(arr: T[]): T[] {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-testimonial]'));
  if (cards.length > 0) {
    const isMobile = window.innerWidth < 768;
    const showCount = isMobile ? 1 : 3;
    const picked = shuffle(cards).slice(0, showCount);
    picked.forEach((card) => card.removeAttribute('hidden'));
  }
</script>
