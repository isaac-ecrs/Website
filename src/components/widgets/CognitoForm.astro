---
interface Props {
  formId: string;
  height?: string;
  title?: string;
}

const { formId, height = '600', title = 'Registration form' } = Astro.props;
const src = `https://www.cognitoforms.com/f/tdXs_w0YA0KlSRyaghpLKw/${formId}`;
---

<div class="ecrs-cognito-form" style="background-color: #fff7ed; padding: 2rem 1rem;">
  <div style="max-width: 48rem; margin: 0 auto;">
    <iframe src={src} allow="payment" style="border:0;width:100%;" height={height} title={title}></iframe>
    <script is:inline src="https://www.cognitoforms.com/f/iframe.js"></script>
  </div>
</div>
