---
interface Props {
  formId: string;
  formName?: string;
  title?: string;
}

const { formId, formName } = Astro.props;
---

<section class="cognito-section">
  <div class="cognito-container" data-cognito-form={formId} data-cognito-form-name={formName}></div>
</section>

<script is:inline data-astro-rerun>
  (function () {
    // Tear down stale Cognito globals so seamless.js re-runs identically to a hard refresh.
    delete window.Cognito;
    delete window.Vue;
    delete window.cfWebpackJsonp;

    document.querySelectorAll('[data-cognito-form]').forEach(function (container) {
      container.innerHTML = '';
      const s = document.createElement('script');
      s.src = 'https://www.cognitoforms.com/f/seamless.js';
      s.dataset.key = 'tdXs_w0YA0KlSRyaghpLKw';
      s.dataset.form = container.dataset.cognitoForm;
      container.appendChild(s);

      // Watch for Cognito adding `is-success` to the form element on submission.
      const observer = new MutationObserver(function () {
        const form = container.querySelector('form.is-success');
        if (form) {
          observer.disconnect();
          const name = container.dataset.cognitoFormName;
          if (name && window.ecrsTrack) {
            window.ecrsTrack('form_submit_' + name, { form_name: name, form_id: container.dataset.cognitoForm });
          }
        }
      });
      observer.observe(container, { subtree: true, attributes: true, attributeFilter: ['class'] });
    });
  })();
</script>

<style>
  .cognito-section {
    padding: 3rem 1rem;
    background-color: var(--aw-color-bg-page);
  }
  .cognito-container {
    max-width: 48rem;
    margin: 0 auto;
  }
</style>
