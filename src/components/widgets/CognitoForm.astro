---
interface Props {
  formId: string;
  title?: string;
}

const { formId } = Astro.props;
---

<section class="cognito-section">
  <div class="cognito-container" data-cognito-form={formId}></div>
</section>

<script is:inline data-astro-rerun>
  (function () {
    // Tear down stale Cognito globals so seamless.js re-runs identically to a hard refresh.
    delete window.Cognito;
    delete window.Vue;
    delete window.cfWebpackJsonp;

    document.querySelectorAll('[data-cognito-form]').forEach(function (container) {
      container.innerHTML = '';
      const s = document.createElement('script');
      s.src = 'https://www.cognitoforms.com/f/seamless.js';
      s.dataset.key = 'tdXs_w0YA0KlSRyaghpLKw';
      s.dataset.form = container.dataset.cognitoForm;
      container.appendChild(s);
    });
  })();
</script>

<script is:inline>
  // TEMP: probe Cognito postMessage format — remove after confirming payload shape
  window.addEventListener('message', function (e) {
    console.log('[CognitoProbe] origin:', e.origin, 'data:', JSON.stringify(e.data));
  });
</script>

<style>
  .cognito-section {
    padding: 3rem 1rem;
    background-color: var(--aw-color-bg-page);
  }
  .cognito-container {
    max-width: 48rem;
    margin: 0 auto;
  }
</style>
