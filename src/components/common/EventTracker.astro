<script is:inline>
  window.ecrsTrack = function (eventName, params) {
    if (window.gtag) {
      window.gtag('event', eventName, params);
    }
    if (window.fbq) {
      const metaMap = {
        form_submit_membership: 'Lead',
        form_submit_contact: 'Lead',
        form_submit_event: 'CompleteRegistration',
        form_submit_donation: 'Donate',
      };
      const metaEvent = metaMap[eventName];
      if (metaEvent) window.fbq('track', metaEvent, params);
    }
    // Future destinations: add an `if (window.newSdk)` block here.
  };
</script>
