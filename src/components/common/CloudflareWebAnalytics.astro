---
import { ANALYTICS } from 'astrowind:config';

// Cloudflare Web Analytics — privacy-first RUM (page views + Core Web Vitals).
// Cookieless and PII-free, so it loads unconditionally with no consent banner.
const token = ANALYTICS?.vendors?.cloudflareWebAnalytics?.token
  ? String(ANALYTICS.vendors.cloudflareWebAnalytics.token)
  : '';
---

{
  token && import.meta.env.PROD && (
    <script
      is:inline
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      integrity="sha384-OLBgp1GsljhM2TJ+sbHjaiH9txEUvgdDTAzHv2P24donTt6/529l+9Ua0vFImLlb"
      crossorigin="anonymous"
      data-cf-beacon={JSON.stringify({ token })}
    />
  )
}
