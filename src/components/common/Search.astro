---
// Site-wide search. Renders a compact magnifying-glass trigger (styled to match
// the header's icon buttons) that opens Pagefind's default modal search UI.
//
// Pagefind indexes the built HTML in dist/ (see the `pagefind()` integration in
// astro.config.ts) and serves the index in dev/preview. The web components below
// are registered once by PagefindConfig's script import and auto-upgrade after
// View Transitions, so no client init is needed here.
import PagefindConfig from 'astro-pagefind/components/PagefindConfig.astro';
---

<div class="ecrs-search inline-flex">
  <PagefindConfig />
  <pagefind-modal-trigger compact hide-shortcut></pagefind-modal-trigger>
  <pagefind-modal></pagefind-modal>
</div>

<script>
  // Pagefind derives result URLs from the dist/<page>/index.html file path, so
  // it emits trailing-slash URLs (e.g. "/our-people/"). The site runs
  // trailingSlash: 'never' and links slash-less everywhere else (navigation.json,
  // permalinks.ts), so those URLs trigger Astro's redirect interstitial. Rewrite
  // result hrefs (which render live as the user types) to the slash-less form the
  // rest of the site already uses. Editing the href attribute also covers
  // middle-click / cmd-click / open-in-new-tab, which a click handler would miss.
  function normalizeHref(a: Element) {
    const href = a.getAttribute('href');
    if (!href || !href.startsWith('/')) return;
    const match = href.match(/^([^?#]*)(.*)$/);
    if (!match) return;
    let path = match[1];
    const rest = match[2];
    if (path.length > 1 && path.endsWith('/')) {
      path = path.slice(0, -1);
      a.setAttribute('href', path + rest);
    }
  }

  const observers = new WeakMap<Element, MutationObserver>();

  function initSearchUrlFix() {
    document.querySelectorAll('pagefind-modal').forEach((modal) => {
      if (observers.has(modal)) return;
      modal.querySelectorAll('a[href]').forEach(normalizeHref);
      const observer = new MutationObserver((mutations) => {
        for (const mutation of mutations) {
          for (const node of mutation.addedNodes) {
            if (!(node instanceof Element)) continue;
            if (node.matches('a[href]')) normalizeHref(node);
            node.querySelectorAll('a[href]').forEach(normalizeHref);
          }
        }
      });
      observer.observe(modal, { childList: true, subtree: true });
      observers.set(modal, observer);
    });
  }

  initSearchUrlFix();
  document.addEventListener('astro:after-swap', initSearchUrlFix);
</script>

<style is:global>
  /* Theme Pagefind's component UI with the ECRS color tokens. The --aw-color-*
     tokens already flip under .dark (see CustomStyles.astro); only the neutral
     border/hover surfaces need explicit dark overrides. */
  pagefind-modal,
  pagefind-modal-trigger {
    --pf-background: var(--aw-color-bg-page);
    --pf-text: var(--aw-color-text-default);
    --pf-text-secondary: var(--aw-color-text-muted);
    --pf-text-muted: var(--aw-color-text-muted);
    --pf-border: rgb(229 231 235); /* gray-200 */
    --pf-border-focus: var(--aw-color-primary);
    --pf-hover: rgb(243 244 246); /* gray-100 */
    --pf-mark: var(--aw-color-primary);
    --pf-modal-backdrop: rgb(0 0 0 / 50%);
  }
  .dark pagefind-modal,
  .dark pagefind-modal-trigger {
    --pf-border: rgb(51 65 85); /* slate-700 */
    --pf-hover: rgb(30 41 59); /* slate-800 */
  }

  /* Restyle the default trigger (a full-width search bar with a border) into a
     compact icon button matching ToggleTheme / the social icons in the header.
     The component ships these styles via a `:is(*, #\#)` specificity hack
     (≈ 3 IDs), which classes alone can't beat, so the overrides use !important. */
  .ecrs-search .pf-trigger-btn {
    width: auto !important;
    height: auto !important;
    padding: 0.625rem !important; /* p-2.5 */
    background: transparent !important;
    border: none !important;
    border-radius: 0.5rem !important; /* rounded-lg */
    color: var(--aw-color-text-muted) !important;
    transition:
      background-color 0.15s,
      color 0.15s !important;
  }
  .ecrs-search .pf-trigger-btn:hover {
    background: rgb(243 244 246) !important; /* gray-100 */
    color: var(--aw-color-primary) !important;
  }
  .dark .ecrs-search .pf-trigger-btn:hover {
    background: rgb(55 65 81) !important; /* gray-700 */
  }
  /* Match the brand-colored focus ring used by the header's other icon buttons,
     replacing the component's default blue outline. */
  .ecrs-search .pf-trigger-btn:focus-visible {
    outline: 2px solid var(--aw-color-primary) !important;
    outline-offset: 2px !important;
  }
  /* The Pagefind glyph fills its whole box, whereas the tabler icons (theme
     toggle, socials) sit in a padded 24px viewBox. Render the glyph a little
     smaller than the 20px box so it reads at the same visual size as the rest. */
  .ecrs-search .pf-trigger-icon {
    width: 1rem !important; /* ~matches tabler glyphs' visible size in a w-5 box */
    height: 1rem !important;
    background: currentColor !important;
  }
</style>
