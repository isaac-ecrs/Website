---
import '@fontsource-variable/inter';
import '@fontsource/oswald/400.css';
import '@fontsource/oswald/700.css';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Oswald';

    /* ECRS Brand — Pink-led palette */
    --aw-color-primary: rgb(189 15 93);      /* Neon Pink 600 — 5.8:1 on white */
    --aw-color-secondary: rgb(148 84 5);     /* Carrot Orange 700 — 5.2:1 on white */
    --aw-color-accent: rgb(0 112 153);       /* Fresh Sky 700 — 4.7:1 on white */

    /* ECRS supplemental tokens */
    --ecrs-color-green: rgb(41 112 47);      /* Medium Jungle 700 */
    --ecrs-color-grey: rgb(54 48 49);        /* Shadow Grey 800 */
    --ecrs-color-pink-light: rgb(244 113 172);  /* Neon Pink 300 — for dark mode */
    --ecrs-color-orange-light: rgb(250 186 107); /* Carrot Orange 300 — for dark mode */
    --ecrs-color-sky-light: rgb(102 214 255);    /* Fresh Sky 300 — for dark mode */

    --aw-color-text-heading: rgb(54 48 49);
    --aw-color-text-default: rgb(54 48 49);
    --aw-color-text-muted: rgb(54 48 49 / 72%);
    --aw-color-bg-page: rgb(255 255 255);

    --aw-color-bg-page-dark: rgb(27 24 25);

    ::selection {
      background-color: rgb(253 208 227);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Oswald';

    --aw-color-primary: rgb(244 113 172);    /* Neon Pink 300 */
    --aw-color-secondary: rgb(250 186 107);  /* Carrot Orange 300 */
    --aw-color-accent: rgb(102 214 255);     /* Fresh Sky 300 */

    --aw-color-text-heading: rgb(243 241 242);
    --aw-color-text-default: rgb(229 226 227);
    --aw-color-text-muted: rgb(229 226 227 / 66%);
    --aw-color-bg-page: rgb(27 24 25);

    ::selection {
      background-color: rgb(94 8 46);
      color: rgb(253 208 227);
    }
  }
</style>
