---
import Image from '~/components/common/Image.astro';

interface Props {
  name: string;
  title?: string;
  photo?: string;
  bio?: string;
}

const { name, title, photo, bio } = Astro.props;
---

<div class="flex gap-4">
  {
    photo ? (
      <Image
        src={photo}
        alt={name}
        width={72}
        height={72}
        widths={[72, 144]}
        sizes="72px"
        layout="cover"
        class="w-18 h-18 rounded-full object-cover flex-shrink-0 mt-1"
      />
    ) : (
      <div
        class="w-18 h-18 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0 mt-1"
        aria-hidden="true"
      >
        <span class="text-2xl font-bold text-primary/60">{name.charAt(0)}</span>
      </div>
    )
  }
  <div class="min-w-0">
    <p class="font-semibold text-heading leading-snug">{name}</p>
    {title && <p class="text-sm text-muted mb-1">{title}</p>}
    {bio && <p class="text-sm text-default mt-1 leading-relaxed">{bio}</p>}
  </div>
</div>
