---
import { SITE } from 'astrowind:config';
---

<img src="/images/ecrs-logo.svg" alt={SITE?.name ?? 'ECRS'} width="43" height="40" class="h-10 w-auto ml-2 rtl:ml-0 rtl:mr-2 dark:hidden" />
<img
  src="/images/ecrs-logo-dark.svg"
  alt={SITE?.name ?? 'ECRS'}
  width="43"
  height="40"
  class="h-10 w-auto ml-2 rtl:ml-0 rtl:mr-2 hidden dark:block"
  fetchpriority="low"
  loading="lazy"
/>
