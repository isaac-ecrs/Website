---
import { SITE } from 'astrowind:config';
---

<img
  src="/images/ecrs-logo.svg"
  alt={SITE?.name ?? 'ECRS'}
  width="46"
  height="44"
  class="h-11 w-auto ml-2 rtl:ml-0 rtl:mr-2 dark:hidden"
  style="width: auto; height: 2.75rem"
/>
<img
  src="/images/ecrs-logo-dark.svg"
  alt={SITE?.name ?? 'ECRS'}
  width="46"
  height="44"
  class="h-11 w-auto ml-2 rtl:ml-0 rtl:mr-2 hidden dark:block"
  style="width: auto; height: 2.75rem"
  fetchpriority="low"
  loading="lazy"
/>
