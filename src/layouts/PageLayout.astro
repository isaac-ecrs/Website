---
import { getCollection } from 'astro:content';
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';

import { headerData, footerData } from '~/navigation';

import type { MetaData } from '~/types';

export interface Props {
  metadata?: MetaData;
  /** When true, this page is excluded from the Pagefind search index. */
  noIndex?: boolean;
}

const { metadata = {}, noIndex = false } = Astro.props;

// Default OG image = next upcoming event's composed card.
// Pages that want a different image (about/contact/donate → /og/default.jpg,
// event detail → /og/<id>.jpg) set metadata.openGraph.images explicitly.
let effectiveMetadata = metadata;
if (!metadata.openGraph?.images?.length) {
  const now = new Date(new Date().toLocaleDateString('en-CA', { timeZone: 'America/New_York' }) + 'T00:00:00Z');
  const allEvents = await getCollection('event', ({ data }) => !data.draft);
  const nextEvent = allEvents
    .filter((e) => (e.data.endDate ?? e.data.date) >= now)
    .sort((a, b) => a.data.date.getTime() - b.data.date.getTime())[0];

  if (nextEvent) {
    effectiveMetadata = {
      ...metadata,
      openGraph: {
        ...metadata.openGraph,
        images: [{ url: `/og/${nextEvent.id}.jpg`, width: 1200, height: 630 }],
      },
    };
  }
}
---

<Layout metadata={effectiveMetadata}>
  <slot name="head" slot="head" />
  <slot name="header">
    <Header {...headerData} isSticky showToggleTheme />
  </slot>
  <main id="main-content" {...noIndex ? { 'data-pagefind-ignore': true } : { 'data-pagefind-body': true }}>
    <slot />
  </main>
  <slot name="footer">
    <Footer {...footerData} />
  </slot>
</Layout>
