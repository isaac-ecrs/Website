{
  "name": "@onwidget/astrowind",
  "version": "1.0.0-beta.63",
  "description": "AstroWind: A free template using Astro 6 and Tailwind CSS v4. Astro starter theme.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "prepare": "lefthook install",
    "predev": "node scripts/copy-sveltia-cms.mjs",
    "dev": "astro dev",
    "prestart": "node scripts/copy-sveltia-cms.mjs",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "npm run check:astro && npm run check:eslint && npm run check:prettier",
    "check:astro": "astro check",
    "check:eslint": "eslint .",
    "check:prettier": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test e2e/accessibility.spec.ts",
    "lighthouse": "npm run build && lhci autorun",
    "fix": "npm run fix:eslint && npm run fix:prettier",
    "fix:eslint": "eslint --fix .",
    "fix:prettier": "prettier -w .",
    "prebuild": "node scripts/copy-sveltia-cms.mjs && node scripts/copy-public-images.mjs && node scripts/process-member-locations.mjs",
    "process-members": "node scripts/process-member-locations.mjs"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.0",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/oswald": "^5.2.8",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vnedyalk0v/react19-simple-maps": "^2.0.9",
    "astro": "^6.4.8",
    "astro-icon": "^1.1.5",
    "astro-pagefind": "^2.0.0",
    "astro-seo": "^1.1.0",
    "lodash.merge": "^4.6.2",
    "pdfmake": "^0.3.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "unpic": "^4.2.2",
    "xlsx": "^0.18.5",
    "zipcodes": "^8.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@iconify-json/flat-color-icons": "^1.2.3",
    "@iconify-json/tabler": "^1.2.35",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@sveltia/cms": "^0.169.1",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash.merge": "^4.6.9",
    "@types/pdfmake": "^0.3.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/coverage-v8": "^4.1.9",
    "astro-compress": "^2.4.1",
    "astro-eslint-parser": "^2.1.0",
    "eslint": "^10.5.0",
    "eslint-plugin-astro": "^2.1.1",
    "globals": "^17.7.0",
    "js-yaml": "^5.2.1",
    "lefthook": "^2.1.9",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "satori": "^0.26.0",
    "sharp": "0.35.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "yaml": ">=2.8.3",
    "vite": "^7"
  },
  "allowScripts": {
    "lefthook@2.1.9": true
  }
}
