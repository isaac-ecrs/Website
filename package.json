{
  "name": "@onwidget/astrowind",
  "version": "1.0.0-beta.63",
  "description": "AstroWind: A free template using Astro 6 and Tailwind CSS v4. Astro starter theme.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && node scripts/inject-sri.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "check": "npm run check:astro && npm run check:eslint && npm run check:prettier",
    "check:astro": "astro check",
    "check:eslint": "eslint .",
    "check:prettier": "prettier --check .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test e2e/accessibility.spec.ts",
    "lighthouse": "astro build && astro preview --port 4321 & sleep 3 && lhci autorun && kill %1",
    "fix": "npm run fix:eslint && npm run fix:prettier",
    "fix:eslint": "eslint --fix .",
    "fix:prettier": "prettier -w .",
    "prebuild": "node scripts/copy-public-images.mjs"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/oswald": "^5.2.8",
    "@fontsource/rubik-distressed": "^5.2.7",
    "astro": "^6.4.8",
    "astro-embed": "^0.13.0",
    "astro-icon": "^1.1.5",
    "astro-pagefind": "^2.0.0",
    "astro-seo": "^1.1.0",
    "limax": "4.2.3",
    "lodash.merge": "^4.6.2",
    "unpic": "^4.2.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/partytown": "^2.1.7",
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@iconify-json/flat-color-icons": "^1.2.3",
    "@iconify-json/tabler": "^1.2.35",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash.merge": "^4.6.9",
    "@types/mdx": "^2.0.14",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "astro-compress": "^2.4.1",
    "astro-eslint-parser": "^2.0.0",
    "eslint": "^10.5.0",
    "eslint-plugin-astro": "^2.0.0",
    "globals": "^17.7.0",
    "js-yaml": "^5.0.0",
    "mdast-util-to-string": "^4.0.0",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "reading-time": "^1.5.0",
    "sharp": "0.35.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "yaml": ">=2.8.3",
    "vite": "^7"
  }
}
