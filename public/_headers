# Cloudflare Pages headers — https://developers.cloudflare.com/pages/configuration/headers/

# Security headers on every response
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Permissions-Policy: camera=(), microphone=(), geolocation=(), browsing-topics=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://static.cloudflareinsights.com https://*.cognitoforms.com https://*.paypal.com https://www.paypalobjects.com https://unpkg.com https://connect.facebook.net; style-src 'self' 'unsafe-inline' https://*.cognitoforms.com https://fonts.googleapis.com; img-src 'self' data: blob: https://images.unsplash.com https://www.facebook.com https://*.cognitoforms.com https://www.paypalobjects.com https://*.paypal.com https://avatars.githubusercontent.com; font-src 'self' data: https://*.cognitoforms.com https://fonts.gstatic.com; connect-src 'self' https://www.google-analytics.com https://analytics.google.com https://region1.google-analytics.com https://cloudflareinsights.com https://*.cognitoforms.com https://*.paypal.com https://www.facebook.com https://unpkg.com https://api.github.com https://www.githubstatus.com; media-src 'self'; frame-src https://*.cognitoforms.com https://*.paypal.com https://assets.braintreegateway.com; frame-ancestors 'self'; worker-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self' https://*.cognitoforms.com https://*.paypal.com; upgrade-insecure-requests

# Astro's content-hashed assets — safe to cache forever
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts rarely change but are not content-hashed — 1 year cache (rename file to bust)
/fonts/*
  Cache-Control: public, max-age=31536000

# CMS-editable media (not content-hashed): cache a day, serve stale up to a week
# while revalidating, so swapping an image under the same filename refreshes.
/images/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800

/videos/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
